{
  "name": "seasonal-race",
  "version": "0.1.0",
  "private": true,
  "description": "Modular race-game platform monorepo",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "security:deps": "corepack pnpm audit --audit-level high",
    "ci:light": "corepack pnpm run lint && corepack pnpm run format:check",
    "ci:extended": "corepack pnpm run ci:light && corepack pnpm run typecheck && corepack pnpm run test",
    "ci:full": "corepack pnpm run ci:extended && corepack pnpm run security:deps"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
